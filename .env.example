# --- LLM provider ---
# Which backend to use for v4 specialist agents and v5 conflict confirmation.
# "anthropic" (default) or "openai".
LLM_PROVIDER=anthropic

# --- Anthropic ---
# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Default model. Cheaper alternatives for iteration: claude-sonnet-4-6,
# claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-opus-4-7

# --- OpenAI ---
# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# Default model. Cheaper alternative for iteration: gpt-4o-mini
OPENAI_MODEL=gpt-4o

# --- Logging (optional) ---
# Default: INFO. Use DEBUG when investigating an agent's behavior.
LOG_LEVEL=INFO
