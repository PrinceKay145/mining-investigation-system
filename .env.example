# --- LLM provider ---
# Which backend to use for v4 specialist agents and v5 conflict confirmation.
# "anthropic" (default), "openai", or "openrouter".
LLM_PROVIDER=anthropic

# --- Anthropic ---
# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Default model. Cheaper alternatives for iteration: claude-sonnet-4-6,
# claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-opus-4-7

# --- OpenAI ---
# Required if LLM_PROVIDER=openai, or for the GPT-4o evaluation judge.
OPENAI_API_KEY=sk-...
# Default model. Cheaper alternative for iteration: gpt-4o-mini
OPENAI_MODEL=gpt-4o

# --- OpenRouter ---
# Required if LLM_PROVIDER=openrouter, or for per-agent OpenRouter clients
# (recommended setup for v4 — see note.md "LLM provisioning" section).
# Deposit $10 of credits on the account to unlock the 1000 :free req/day tier.
OPENROUTER_API_KEY=sk-or-v1-...

# Per-role model assignments. See note.md for the rationale behind each pick.
# Override here to swap a model without code changes. Verify model IDs with
# `python scripts/ping_openrouter.py --list-free` before changing.
# Hybrid strategy: free :free models where they work; paid (no `:free` suffix)
# on the three roles where the free-pool's Venice upstream provider rate-limited
# us during 2026-05-14 verification. Paying for those three keeps total spend
# well under $5 across an entire thesis-grade evaluation campaign. See
# note.md "Hybrid free / paid pricing strategy" for the per-role math.
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL_TECHNICAL=openai/gpt-oss-120b:free
OPENROUTER_MODEL_ORGANIZATIONAL=qwen/qwen3-235b-a22b-2507
OPENROUTER_MODEL_CHALLENGER=mistralai/mistral-small-3.2-24b-instruct
OPENROUTER_MODEL_REGULATORY=meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL_V5_CONFIRMATION=openai/gpt-oss-20b:free
OPENROUTER_MODEL_V6_REPORT=meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL_V1_EXTRACTION=deepseek/deepseek-v4-flash:free

# Optional OpenRouter attribution headers — used for OpenRouter's analytics
# and leaderboards. Safe to leave commented out.
# OPENROUTER_HTTP_REFERER=https://github.com/your/repo
# OPENROUTER_X_TITLE=mining-investigation-system

# --- Logging (optional) ---
# Default: INFO. Use DEBUG when investigating an agent's behavior.
LOG_LEVEL=INFO
